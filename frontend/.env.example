# Backend origin for Vite dev-server proxy (development only)
VITE_BACKEND_URL=http://localhost:8000

# API base URL for the app (used at build time)
# - Use "/api" when the same host proxies /api to the backend (e.g. nginx or Vite proxy)
# - Use full URL (e.g. http://localhost:8000) when calling the backend directly (CORS must allow it)
# VITE_API_BASE_URL=/api
