pipeline {
    agent any

    triggers {
        pollSCM 'H/10 * * * *'
    }

    environment {
        BE_IMAGE = "flashy-backend"
        FE_IMAGE = "flashy-frontend"

        BE_SSH_HOST = "localhost"
        BE_SSH_PORT = "2224"
        FE_SSH_HOST = "localhost"
        FE_SSH_PORT = "2225"


        SSH_USER = "jenkins"
        SSH_KEY_PATH = "~/ssh_key/id_rsa"

        BE_REMOTE_DIR = "/home/jenkins/flashy/backend"
        FE_REMOTE_DIR = "/home/jenkins/flashy/frontend"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Backend Image') {
            steps {
                script {
                    sh """
                        docker build \
                          -t ${BE_IMAGE}:latest \
                          -t ${BE_IMAGE}:${BUILD_NUMBER} \
                          -f backend/Dockerfile \
                          backend
                    """
                }
            }
        }

        stage('Build Frontend Image') {
            steps {
                script {
                    sh """
                        docker build \
                          -t ${FE_IMAGE}:latest \
                          -t ${FE_IMAGE}:${BUILD_NUMBER} \
                          -f frontend/Dockerfile.prod \
                          frontend
                    """
                }
            }
        }

        stage('Package Images') {
            steps {
                script {
                    sh """
                        rm -f backend-image.tar frontend-image.tar
                        docker save ${BE_IMAGE}:latest -o backend-image.tar
                        docker save ${FE_IMAGE}:latest -o frontend-image.tar
                    """
                }
            }
        }

        stage('Transfer Backend Image') {
            steps {
                script {
                    sh """
                        ssh -i ${SSH_KEY_PATH} -p ${BE_SSH_PORT} -o StrictHostKeyChecking=no ${SSH_USER}@${BE_SSH_HOST} "mkdir -p ${BE_REMOTE_DIR}"
                        scp -i ${SSH_KEY_PATH} -P ${BE_SSH_PORT} -o StrictHostKeyChecking=no backend-image.tar ${SSH_USER}@${BE_SSH_HOST}:${BE_REMOTE_DIR}/backend-image.tar
                    """
                }
            }
        }

        stage('Transfer Frontend Image') {
            steps {
                script {
                    sh """
                        ssh -i ${SSH_KEY_PATH} -p ${FE_SSH_PORT} -o StrictHostKeyChecking=no ${SSH_USER}@${FE_SSH_HOST} "mkdir -p ${FE_REMOTE_DIR}"
                        scp -i ${SSH_KEY_PATH} -P ${FE_SSH_PORT} -o StrictHostKeyChecking=no frontend-image.tar ${SSH_USER}@${FE_SSH_HOST}:${FE_REMOTE_DIR}/frontend-image.tar
                    """
                }
            }
        }

        stage('Deploy Backend') {
            steps {
                script {
                    sh """
                        ssh -i ${SSH_KEY_PATH} -p ${BE_SSH_PORT} -o StrictHostKeyChecking=no ${SSH_USER}@${BE_SSH_HOST} '
                          cd ${BE_REMOTE_DIR} && \
                          sudo docker load -i backend-image.tar && \
                          sudo docker compose up -d --remove-orphans
                        '
                    """
                }
            }
        }

        stage('Deploy Frontend') {
            steps {
                script {
                    sh """
                        ssh -i ${SSH_KEY_PATH} -p ${FE_SSH_PORT} -o StrictHostKeyChecking=no ${SSH_USER}@${FE_SSH_HOST} '
                          cd ${FE_REMOTE_DIR} && \
                          sudo docker load -i frontend-image.tar && \
                          sudo docker compose up -d --remove-orphans
                        '
                    """
                }
            }
        }

        stage('Backend Smoke Check') {
            steps {
                script {
                    sh """
                        set -e
                        for i in \$(seq 1 30); do
                            if curl -fsS http://${BE_SSH_HOST}:8000/health >/dev/null; then
                                exit 0
                            fi
                            sleep 2
                        done
                        echo "Backend health check failed after retries"
                        exit 1
                    """
                }
            }
        }

        stage('Frontend Smoke Check') {
            steps {
                script {
                    sh """
                        set -e
                        for i in \$(seq 1 30); do
                            if curl -fsS http://${FE_SSH_HOST}/health >/dev/null; then
                                exit 0
                            fi
                            sleep 2
                        done
                        echo "Frontend health check failed after retries"
                        exit 1
                    """
                }
            }
        }
    }
}
