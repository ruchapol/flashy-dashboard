FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# No default command; override when running, e.g.:
#   docker compose run backend_batch python -m app.seed_db
CMD ["python", "-c", "pass"]

